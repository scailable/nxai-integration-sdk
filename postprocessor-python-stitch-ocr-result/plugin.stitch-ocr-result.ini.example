[common]
# Logging level (DEBUG, INFO, WARNING, ERROR)
log_level = DEBUG
# Path to Unix socket for communication with AI Manager
socket_path = /tmp/postprocessor-stitch-ocr-result.sock
# Path to the log file
log_file = /tmp/postprocessor-stitch-ocr-result.log
# Path to nxai-utilities (autodetected if not set)
# nxai_utilities_path = ../nxai-utilities/python-utilities

[ocr]
# Number of parallel workers for OCR processing
worker_count = 4
# Name of the OCR model output tensor
output_name = Identity:0
